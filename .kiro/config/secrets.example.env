# QA Agent secrets — example
#
# Copy this file to `.env` in the same directory and fill values.
# `.env` is gitignored. NEVER commit real secrets to this file.
#
# Naming convention: QA_<env>_<role>_<field>
# See ../steering/12-secrets-management.md for the full policy.

# ─── Jira (consumed by the Jira MCP server) ────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=qa-bot@your-org.com
JIRA_API_TOKEN=

# ─── Target environments ───────────────────────────────────────────────────
QA_STAGING_BASE_URL=https://staging.example.com
QA_LOCAL_BASE_URL=http://localhost:3000
QA_PROD_BASE_URL=https://example.com  # use only with @prod-safe scenarios

# ─── Test users — staging ──────────────────────────────────────────────────
QA_STAGING_USER_EMAIL=qa.user+staging@example.com
QA_STAGING_USER_PASSWORD=
QA_STAGING_ADMIN_EMAIL=qa.admin+staging@example.com
QA_STAGING_ADMIN_PASSWORD=

# ─── MFA seeds (base32) — optional ─────────────────────────────────────────
# Only populate if the test account uses TOTP and you've recorded the seed.
TOTP_SECRET_STAGING_USER=
TOTP_SECRET_STAGING_ADMIN=

# ─── Sandbox payment keys — never use live keys here ───────────────────────
STRIPE_SANDBOX_KEY=
PAYPAL_SANDBOX_CLIENT_ID=

# ─── Optional alternate backends ───────────────────────────────────────────
# Uncomment one to switch backends. See ../steering/12-secrets-management.md
# OP_VAULT=Engineering-QA              # 1Password CLI
# AWS_SECRETS_PREFIX=/qa-agent/        # AWS Secrets Manager
# VAULT_ADDR=https://vault.example.com # HashiCorp Vault
